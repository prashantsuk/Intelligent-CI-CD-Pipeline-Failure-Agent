# Environment Configuration
# Copy this to .env and update with your actual values

# Application Settings
ENVIRONMENT=development
PORT=5000
DEBUG=False

# Docker Configuration
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
REGISTRY=docker.io

# GitHub Configuration
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=Intelligent-CI-CD-Pipeline-Failure-Agent

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# S3 Configuration
FAILURE_LOGS_BUCKET=pipeline-failure-logs-your-account-id

# SNS Configuration
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:your-account-id:pipeline-failure-notifications
SNS_EMAIL_ADDRESS=your-email@example.com

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Lambda Configuration
LAMBDA_FUNCTION_NAME=pipeline-failure-analyzer
LAMBDA_TIMEOUT=300
LAMBDA_MEMORY_SIZE=512
